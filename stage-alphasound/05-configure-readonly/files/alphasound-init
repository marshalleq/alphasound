#!/bin/bash
# alphasound-init: Reads /boot/firmware/alphasound.txt and configures the system
# Runs at boot before shairport-sync and networking services

set -e

CONFIG_FILE="/boot/firmware/alphasound.txt"

# Defaults
ALPHASOUND_MODE="RUN"
ALPHASOUND_SSID="Alphasound"
ALPHASOUND_NAME="Alphasound"
ALPHASOUND_CHANNEL="11"
ALPHASOUND_COUNTRY="NZ"
ALPHASOUND_OUTPUT_DEVICE="hw:0"
ALPHASOUND_DAC_OVERLAY="hifiberry-dac"
ALPHASOUND_VOLUME_MAX_DB="-3.00"
ALPHASOUND_DEV_WIFI_SSID=""
ALPHASOUND_DEV_WIFI_PASSWORD=""

# Read config file (ignore comments and blank lines)
if [ -f "$CONFIG_FILE" ]; then
    while IFS='=' read -r key value; do
        # Skip comments and empty lines
        [[ "$key" =~ ^[[:space:]]*# ]] && continue
        [[ -z "$key" ]] && continue
        # Trim whitespace
        key=$(echo "$key" | xargs)
        value=$(echo "$value" | xargs)
        # Export valid config keys
        case "$key" in
            ALPHASOUND_*) declare "$key=$value" ;;
        esac
    done < "$CONFIG_FILE"
fi

# Disable WiFi power saving
/sbin/iw dev wlan0 set power_save off 2>/dev/null || true

if [ "$ALPHASOUND_MODE" = "RUN" ]; then
    #
    # === CAR MODE ===
    # Create WiFi AP, no internet gateway, run shairport-sync
    #

    # Generate hostapd config from template
    sed -e "s/%%SSID%%/$ALPHASOUND_SSID/g" \
        -e "s/%%CHANNEL%%/$ALPHASOUND_CHANNEL/g" \
        -e "s/%%COUNTRY%%/$ALPHASOUND_COUNTRY/g" \
        /etc/hostapd/hostapd.conf.template > /tmp/hostapd.conf

    # Update shairport-sync config
    cat > /tmp/shairport-sync.conf << EOF
general =
{
    name = "$ALPHASOUND_NAME";
    ignore_volume_control = "yes";
    volume_max_db = $ALPHASOUND_VOLUME_MAX_DB;
};

alsa =
{
    output_device = "$ALPHASOUND_OUTPUT_DEVICE";
};
EOF
    cp /tmp/shairport-sync.conf /etc/shairport-sync.conf 2>/dev/null || true

    # Start WiFi access point
    /usr/sbin/hostapd -B -P /run/hostapd.pid /tmp/hostapd.conf
    /sbin/ip addr add 10.0.10.1/24 dev wlan0
    /bin/systemctl start isc-dhcp-server

else
    #
    # === DEV MODE ===
    # Join existing WiFi network for development/updates
    #

    # Re-enable normal networking
    systemctl start wpa_supplicant || true
    systemctl start dhcpcd 2>/dev/null || systemctl start NetworkManager 2>/dev/null || true

    # If dev WiFi credentials are provided, connect
    if [ -n "$ALPHASOUND_DEV_WIFI_SSID" ]; then
        # Create wpa_supplicant config
        cat > /tmp/wpa_supplicant.conf << EOF
ctrl_interface=DIR=/var/run/wpa_supplicant GROUP=netdev
update_config=1
country=$ALPHASOUND_COUNTRY

network={
    ssid="$ALPHASOUND_DEV_WIFI_SSID"
    psk="$ALPHASOUND_DEV_WIFI_PASSWORD"
}
EOF
        wpa_supplicant -B -i wlan0 -c /tmp/wpa_supplicant.conf 2>/dev/null || true
        dhclient wlan0 2>/dev/null || true
    fi

    sleep 2
    systemctl start systemd-timesyncd || true
fi
