#!/bin/sh
# Accept a raw apkovl tarball POST'd to stdin, validate, swap, reboot.
#
# We stream the body straight onto the SD card's boot partition rather
# than via tmpfs: the root tmpfs on a Pi Zero 2 W is ~200 MB and already
# ~90% full with the extracted apkovl, so a 60 MB upload through /tmp
# would fill it. The SD has gigabytes free, and since the file has to
# end up there anyway (alphasound.apkovl.tar.gz), writing directly
# saves a round-trip.
#
# Combined with lighttpd's server.stream-request-body = 1, no large
# buffer exists anywhere along the request path.

. /etc/alphasound/session.sh
. /etc/alphasound/reply.sh
require_session

set -e

BOOT=/media/mmcblk0p1
APKOVL=$BOOT/alphasound.apkovl.tar.gz
BAK=$BOOT/alphasound.apkovl.tar.gz.bak
NEW=$BOOT/alphasound.apkovl.tar.gz.new

REMOUNT_RW=0
cleanup() {
    rm -f "$NEW" 2>/dev/null
    [ "$REMOUNT_RW" = 1 ] && mount -o remount,ro "$BOOT" 2>/dev/null
    return 0
}
trap cleanup EXIT

[ "$REQUEST_METHOD" = "POST" ] || reply "405 Method Not Allowed" "POST a tarball as the request body"
[ -n "$CONTENT_LENGTH" ] && [ "$CONTENT_LENGTH" -gt 0 ] || reply "411 Length Required" "missing or empty body"

# Pre-flight: confirm the SD partition has room for the body + a small
# buffer. df works on the read-only mount; we want to fail here rather
# than 90s into a slow upload when the filesystem fills up mid-write.
avail_kb=$(df -k "$BOOT" 2>/dev/null | awk 'NR==2 { print $4 }')
needed_kb=$(( (CONTENT_LENGTH + 1023) / 1024 + 2048 ))
if [ -n "$avail_kb" ] && [ "$avail_kb" -lt "$needed_kb" ]; then
    reply "507 Insufficient Storage" "not enough free space on SD: need ~${needed_kb}KB, have ${avail_kb}KB"
fi

# Drive the on-device "Updating..." overlay on the display service by
# writing the current stage into /tmp/alphasound-updating. The display
# service polls this file and paints whatever's in it. Tmpfs wipes the
# file at reboot so the handoff to the boot splash is automatic.
STATUS=/tmp/alphasound-updating
status() { echo "$1" > "$STATUS" 2>/dev/null; }

status "Receiving update…"

mount -o remount,rw "$BOOT"
REMOUNT_RW=1

head -c "$CONTENT_LENGTH" > "$NEW"

status "Validating…"

# Accept either a gzipped tar or a bare tar; re-gzip the bare case so
# the boot-time apkovl reader (which only knows .tar.gz) is happy.
if tar -tzf "$NEW" >/dev/null 2>&1; then
    :
elif tar -tf "$NEW" >/dev/null 2>&1; then
    status "Recompressing…"
    gzip -c "$NEW" > "$NEW.gz" 2>/dev/null \
        || reply "500 Internal Server Error" "re-gzip failed"
    mv "$NEW.gz" "$NEW"
else
    reply "400 Bad Request" "uploaded file is not a valid tar or tar.gz"
fi

. /etc/alphasound/apkovl-check.sh
check_apkovl_compat "$NEW"

status "Applying update…"

mv "$APKOVL" "$BAK" 2>/dev/null || true
mv "$NEW" "$APKOVL"
touch "$BOOT/.boot_pending"
rm -f "$BOOT/.boot_count"
sync
mount -o remount,ro "$BOOT" 2>/dev/null || true

status "Rebooting…"

# Swap + remount done; cleanup trap is no longer needed.
REMOUNT_RW=0
trap - EXIT

reply_and_reboot "update applied — rebooting. Reconnect to the AP in ~30s."
