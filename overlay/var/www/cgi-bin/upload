#!/bin/sh
# Accept a raw apkovl tarball POST'd to stdin, validate, swap, reboot.
#
# Several interventions needed to survive busybox httpd's behaviour on
# large uploads:
#   1. Commit to 200 OK and start streaming the response BEFORE
#      consuming the request body. busybox kills CGIs that go silent
#      on stdout for too long, and reading 60 MB over WiFi easily
#      exceeds that window.
#   2. Emit a stdout heartbeat ("." every few seconds) while the body
#      streams in, so the CGI-read timer never lapses regardless of
#      how slow the client's WiFi is.
#   3. Stream the body directly to the final SD location (.new), not
#      tmpfs + cross-filesystem mv — avoids copying 60 MB twice.
#   4. Fork the sync + reboot into a subshell detached from httpd's
#      stdio so the parent exits cleanly and httpd flushes the
#      response to the client without waiting.
#
# Trade-off: we commit to 200 OK before validating, so a malformed
# upload produces "200 OK with ERROR text in body" rather than a 400
# status. Acceptable — the auto-rollback safety net on SD catches
# apkovls that install but then fail to boot 3 times.

. /etc/alphasound/session.sh
require_session

set -e

BOOT=/media/mmcblk0p1
APKOVL=$BOOT/alphasound.apkovl.tar.gz
BAK=$BOOT/alphasound.apkovl.tar.gz.bak
NEW=$BOOT/alphasound.apkovl.tar.gz.new

REMOUNT_RW=0
HEARTBEAT=""
cleanup() {
    [ -n "$HEARTBEAT" ] && kill "$HEARTBEAT" 2>/dev/null
    rm -f "$NEW" 2>/dev/null
    [ "$REMOUNT_RW" = 1 ] && mount -o remount,ro "$BOOT" 2>/dev/null
    return 0
}
trap cleanup EXIT

early_reply() {
    printf 'Status: %s\r\nContent-Type: text/plain\r\n\r\n%s\n' "$1" "$2"
    exit
}

[ "$REQUEST_METHOD" = "POST" ] || early_reply "405 Method Not Allowed" "POST a tarball as the request body"
[ -n "$CONTENT_LENGTH" ] && [ "$CONTENT_LENGTH" -gt 0 ] || early_reply "411 Length Required" "missing or empty body"

# ---- commit to 200 OK, start response, kick off heartbeat ----------
printf 'Status: 200 OK\r\nContent-Type: text/plain\r\n\r\n'
printf 'receiving %s bytes ' "$CONTENT_LENGTH"

(while sleep 4; do printf '.\n'; done) &
HEARTBEAT=$!

# ---- remount boot rw and stream body straight to SD ---------------
mount -o remount,rw "$BOOT"
REMOUNT_RW=1

set +e
head -c "$CONTENT_LENGTH" > "$NEW"
rc=$?
set -e
if [ "$rc" -ne 0 ]; then
    printf '\nERROR: upload interrupted\n'
    exit 1
fi

printf ' ok\n'

# ---- validate: must be a gzipped tar, or a bare tar we can re-gzip -
if tar -tzf "$NEW" >/dev/null 2>&1; then
    :
elif tar -tf "$NEW" >/dev/null 2>&1; then
    printf 'gzipping (client pre-extracted the wrapper)... '
    if gzip -c "$NEW" > "$NEW.gz" 2>/dev/null && mv "$NEW.gz" "$NEW"; then
        printf 'ok\n'
    else
        printf 'failed\n'
        exit 1
    fi
else
    printf 'ERROR: not a valid tar or tar.gz\n'
    exit 1
fi

# Major-version compat. Subshell isolates apkovl-check.sh's `exit` call
# so it can't abort our flow or inject its own Status header over ours.
if ! ( . /etc/alphasound/apkovl-check.sh; check_apkovl_compat "$NEW" >/dev/null 2>&1 ); then
    printf 'ERROR: apkovl Alpine major version mismatch (see /var/log/messages)\n'
    logger -t alphasound-upload "apkovl compat check failed" 2>/dev/null || true
    exit 1
fi

# ---- swap (same-filesystem rename, instant), stop heartbeat -------
mv "$APKOVL" "$BAK" 2>/dev/null || true
mv "$NEW" "$APKOVL"
touch "$BOOT/.boot_pending"
rm -f "$BOOT/.boot_count"

kill "$HEARTBEAT" 2>/dev/null
wait "$HEARTBEAT" 2>/dev/null
HEARTBEAT=""

printf 'installed — rebooting, reconnect to the AP in ~30s\n'

# Background subshell owns the SD remount now.
REMOUNT_RW=0
trap - EXIT

(
    exec >/dev/null 2>&1 </dev/null
    sync
    mount -o remount,ro "$BOOT" 2>/dev/null || true
    reboot
) &

exit 0
