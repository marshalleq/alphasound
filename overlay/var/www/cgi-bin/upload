#!/bin/sh
# Accept a raw apkovl tarball POST'd to stdin, validate, swap, reboot.
#
# Under lighttpd the whole request body is already buffered by the
# server by the time the CGI starts — we just read CONTENT_LENGTH
# bytes from stdin and process normally. No heartbeats, no chunking,
# no response-before-body games needed (those were workarounds for
# busybox httpd's quirks, which we're no longer using).

. /etc/alphasound/session.sh
require_session

set -e

BOOT=/media/mmcblk0p1
APKOVL=$BOOT/alphasound.apkovl.tar.gz
BAK=$BOOT/alphasound.apkovl.tar.gz.bak
TMP=/tmp/alphasound.upload.$$

reply() {
    printf 'Status: %s\r\nContent-Type: text/plain\r\n\r\n%s\n' "$1" "$2"
    exit
}

trap 'rm -f "$TMP"' EXIT

[ "$REQUEST_METHOD" = "POST" ] || reply "405 Method Not Allowed" "POST a tarball as the request body"
[ -n "$CONTENT_LENGTH" ] && [ "$CONTENT_LENGTH" -gt 0 ] || reply "411 Length Required" "missing or empty body"

head -c "$CONTENT_LENGTH" > "$TMP"

# Accept either a gzipped tar or a bare tar; re-gzip the bare case so
# the boot-time apkovl reader (which only knows .tar.gz) is happy.
if tar -tzf "$TMP" >/dev/null 2>&1; then
    :
elif tar -tf "$TMP" >/dev/null 2>&1; then
    gzip -c "$TMP" > "$TMP.gz" 2>/dev/null \
        || reply "500 Internal Server Error" "re-gzip failed"
    mv "$TMP.gz" "$TMP"
else
    reply "400 Bad Request" "uploaded file is not a valid tar or tar.gz"
fi

. /etc/alphasound/apkovl-check.sh
check_apkovl_compat "$TMP"

mount -o remount,rw "$BOOT"
mv "$APKOVL" "$BAK" 2>/dev/null || true
mv "$TMP" "$APKOVL"
touch "$BOOT/.boot_pending"
rm -f "$BOOT/.boot_count"
sync
mount -o remount,ro "$BOOT" 2>/dev/null || true

# TMP has been moved; disable the cleanup trap.
trap - EXIT

# Reboot in the background so the HTTP response flushes to the client
# before the device goes offline.
( sleep 1; reboot ) &
reply "200 OK" "update applied — rebooting. Reconnect to the AP in ~30s."
