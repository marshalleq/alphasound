#!/bin/sh
# Update feature toggles in alphasound.txt and reboot.
#
# Form fields (POST, application/x-www-form-urlencoded):
#   bluetooth = yes|no
#   sshd      = yes|no
#   display   = none|hdmi|pirate-audio|adafruit-1.3-tft|adafruit-mini-pitft
#   output    = auto|hdmi
#   roon      = yes|no
#
# When display=pirate-audio, we also write a managed block into usercfg.txt
# to uncomment dtoverlay=hifiberry-dac — the Pirate Audio HAT is that DAC
# and has no HAT-spec EEPROM, so it can't announce itself to the firmware.

. /etc/alphasound/session.sh
require_session

set -e

CONFIG=/media/mmcblk0p1/alphasound.txt
USERCFG=/media/mmcblk0p1/usercfg.txt

reply() {
    code=$1; body=$2
    printf 'Status: %s\r\n' "$code"
    printf 'Content-Type: text/plain\r\n\r\n'
    printf '%s\n' "$body"
    exit
}

[ "$REQUEST_METHOD" = "POST" ] || reply "405 Method Not Allowed" "use POST"

DATA=$(head -c "${CONTENT_LENGTH:-0}")

urldecode() {
    s=$(printf '%s' "$1" | sed 's/+/ /g')
    printf '%b' "$(printf '%s' "$s" | sed 's/%\([0-9a-fA-F][0-9a-fA-F]\)/\\x\1/g')"
}
field() {
    raw=$(printf '%s' "$DATA" | tr '&' '\n' | grep "^$1=" | head -1 | cut -d= -f2-)
    urldecode "$raw"
}

BT=$(field bluetooth)
SSH=$(field sshd)
DISPLAY=$(field display)
OUTPUT=$(field output)
ROON=$(field roon)

# Validate
case "$BT" in yes|no) ;; *) reply "400 Bad Request" "bluetooth must be yes/no" ;; esac
case "$SSH" in yes|no) ;; *) reply "400 Bad Request" "sshd must be yes/no" ;; esac
case "$ROON" in yes|no) ;; *) reply "400 Bad Request" "roon must be yes/no" ;; esac
case "$DISPLAY" in none|hdmi|pirate-audio|adafruit-1.3-tft|adafruit-mini-pitft) ;;
    *) reply "400 Bad Request" "display value not recognised" ;;
esac
case "$OUTPUT" in auto|hdmi) ;; *) reply "400 Bad Request" "output must be auto or hdmi" ;; esac

update_config() {
    key=$1
    value=$(printf '%s' "$2" | sed 's/[\\|]/\\&/g')
    if grep -q "^${key}=" "$CONFIG"; then
        sed -i "s|^${key}=.*|${key}=${value}|" "$CONFIG"
    else
        printf '%s=%s\n' "$key" "$2" >> "$CONFIG"
    fi
}

# Rewrite the alphasound-managed block at the end of usercfg.txt. Only
# the marker-bounded region is touched; anything the user has added
# above it (a custom DAC overlay, extra dtparams) is left alone.
update_usercfg() {
    [ -f "$USERCFG" ] || touch "$USERCFG"
    tmp=/tmp/usercfg.$$
    awk '
        /^# >>> alphasound-managed >>>/ { skip=1; next }
        skip && /^# <<< alphasound-managed <<</ { skip=0; next }
        !skip { print }
    ' "$USERCFG" > "$tmp"

    {
        printf '\n# >>> alphasound-managed >>>\n'
        printf '# Auto-generated from the web UI. Edits inside this block\n'
        printf '# are overwritten on every Apply.\n'
        if [ "$DISPLAY" = "pirate-audio" ]; then
            printf 'dtoverlay=hifiberry-dac\n'
        fi
        printf '# <<< alphasound-managed <<<\n'
    } >> "$tmp"

    mv "$tmp" "$USERCFG"
}

mount -o remount,rw /media/mmcblk0p1
update_config ALPHASOUND_BLUETOOTH "$BT"
update_config ALPHASOUND_SSHD "$SSH"
update_config ALPHASOUND_DISPLAY "$DISPLAY"
update_config ALPHASOUND_OUTPUT_DEVICE "$OUTPUT"
update_config ALPHASOUND_ROON "$ROON"
update_usercfg
sync
mount -o remount,ro /media/mmcblk0p1 2>/dev/null || true

( sleep 1; reboot ) &
reply "200 OK" "features updated — rebooting now"
