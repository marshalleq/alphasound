#!/bin/sh
# Returns current device status as JSON for the web UI.

. /etc/alphasound/session.sh
require_session

svc() { rc-service "$1" status >/dev/null 2>&1 && echo true || echo false; }
proc() { pgrep -x "$1" >/dev/null 2>&1 && echo true || echo false; }

VERSION=$(cat /etc/alphasound-version 2>/dev/null || echo unknown)
UPTIME=$(uptime 2>/dev/null | sed 's/^.*up *//; s/, *load.*$//; s/, *[0-9]* *user.*$//')
IP=$(ip -4 -o addr show wlan0 2>/dev/null | awk '{print $4}')
PENDING_COUNT=$(cat /media/mmcblk0p1/.boot_count 2>/dev/null)
[ ! -f /media/mmcblk0p1/.boot_pending ] && PENDING_COUNT=0
PENDING_COUNT=${PENDING_COUNT:-0}

# Pull mode + client SSID from alphasound.txt to pre-populate the UI form.
config_get() {
    grep "^$1=" /media/mmcblk0p1/alphasound.txt 2>/dev/null | head -1 | cut -d= -f2-
}
MODE=$(config_get ALPHASOUND_MODE)
DEV_SSID=$(config_get ALPHASOUND_DEV_WIFI_SSID)
FEAT_BT=$(config_get ALPHASOUND_BLUETOOTH)
FEAT_SSH=$(config_get ALPHASOUND_SSHD)
FEAT_DISPLAY=$(config_get ALPHASOUND_DISPLAY)
FEAT_OUTPUT=$(config_get ALPHASOUND_OUTPUT_DEVICE)
FEAT_BRIGHT=$(config_get ALPHASOUND_DISPLAY_BRIGHTNESS)
FEAT_ROON=$(config_get ALPHASOUND_ROON)
[ -z "$FEAT_BT" ] && FEAT_BT=yes
[ -z "$FEAT_SSH" ] && FEAT_SSH=yes
[ -z "$FEAT_DISPLAY" ] && FEAT_DISPLAY=none
[ -z "$FEAT_OUTPUT" ] && FEAT_OUTPUT=auto
[ -z "$FEAT_ROON" ] && FEAT_ROON=no
case "$FEAT_BRIGHT" in ""|*[!0-9]*) FEAT_BRIGHT=50 ;; esac
[ "$FEAT_BRIGHT" -gt 100 ] && FEAT_BRIGHT=100
# The UI dropdown only knows auto and hdmi. If the user has hand-set a
# raw hw:... value, report it as 'auto' so their edit isn't clobbered
# the next time they hit Apply without touching the dropdown.
case "$FEAT_OUTPUT" in auto|hdmi) ;; *) FEAT_OUTPUT=auto ;; esac
ROON_INSTALLED=false
[ -f /media/mmcblk0p1/persist/roon/RoonBridge.tar.bz2 ] && ROON_INSTALLED=true

# Boot timing checkpoints from /tmp/alphasound-boot-time. Returns the
# "ready" line's seconds value; client can show the breakdown.
BOOT_READY=$(awk '$1=="ready" { print $2 }' /tmp/alphasound-boot-time 2>/dev/null)
[ -z "$BOOT_READY" ] && BOOT_READY=0
BOOT_BREAKDOWN_JSON='{}'
if [ -f /tmp/alphasound-boot-time ]; then
    BOOT_BREAKDOWN_JSON=$(awk 'BEGIN{ printf "{" } { printf "%s\"%s\":%s", sep, $1, $2; sep="," } END{ printf "}" }' /tmp/alphasound-boot-time)
fi

# JSON-escape: only need to handle backslash and double quote for our values.
json_esc() { printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'; }

cat << EOF
Content-Type: application/json
Cache-Control: no-store

{
  "version": "$(json_esc "$VERSION")",
  "uptime": "$(json_esc "$UPTIME")",
  "ip": "$(json_esc "$IP")",
  "mode": "$(json_esc "$MODE")",
  "dev_ssid": "$(json_esc "$DEV_SSID")",
  "features": {
    "bluetooth":  "$FEAT_BT",
    "sshd":       "$FEAT_SSH",
    "display":    "$FEAT_DISPLAY",
    "output":     "$FEAT_OUTPUT",
    "brightness": $FEAT_BRIGHT,
    "roon":       "$FEAT_ROON"
  },
  "roon_installed": $ROON_INSTALLED,
  "boot_seconds": $BOOT_READY,
  "boot_checkpoints": $BOOT_BREAKDOWN_JSON,
  "pending_update": $PENDING_COUNT,
  "services": {
    "hostapd":        $(proc hostapd),
    "dnsmasq":        $(svc dnsmasq),
    "shairport-sync": $(svc shairport-sync),
    "bluetoothd":     $(svc bluetooth),
    "bluealsad":      $(svc bluealsa),
    "sshd":           $(svc sshd)
  }
}
EOF
